<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 14px;">
  <tr>
    <td style="background-color:#E8F0FE; border-radius:999px; padding:7px 14px;">
      <span style="font-size:11px; font-weight:800; letter-spacing:1.1px; text-transform:uppercase; color:#004198;">Cupom para você</span>
    </td>
  </tr>
</table>

<h1 class="h1" style="margin:0 0 12px; font-size:26px; line-height:1.22; font-weight:800; color:#0F172A; letter-spacing:-0.6px;">
  {{#if cliente_nome}}{{cliente_nome}}, a {{loja.nome}} preparou um desconto para você{{else}}A {{loja.nome}} preparou um desconto para você{{/if}}
</h1>

<p style="margin:0 0 28px; font-size:15px; line-height:1.7; color:#4B5563;">
  {{#if motivo}}{{motivo}}{{else}}Como você já pediu aqui antes, a loja separou uma condição especial para o seu próximo pedido.{{/if}}
</p>

<!-- Cupom -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#070C18; border-radius:16px;">
  <tr>
    <td align="center" style="padding:30px 24px 26px;">
      <div style="font-size:11px; font-weight:700; letter-spacing:1.4px; text-transform:uppercase; color:#8A93A3; margin-bottom:10px;">Desconto exclusivo</div>
      <div style="font-size:44px; font-weight:800; color:#FC5B24; line-height:1; letter-spacing:-1.5px;">{{valor_exibicao}}</div>
      <div style="font-size:14px; color:#A6AEBC; margin-top:8px; line-height:1.5;">{{descricao}}</div>

      <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:20px auto 0;">
        <tr>
          <td style="background-color:#FFFFFF; border-radius:10px; padding:13px 26px;">
            <span style="font-family:ui-monospace,SFMono-Regular,Menlo,monospace; font-size:21px; font-weight:800; letter-spacing:3px; color:#070C18;">{{codigo}}</span>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:18px; border:1px solid #E4EAF2; border-radius:14px;">
  <tr>
    <td style="padding:16px 20px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        {{#if pedido_minimo}}
        <tr>
          <td style="font-size:13px; color:#6B7280;">Pedido mínimo</td>
          <td align="right" style="font-size:13px; font-weight:700; color:#0F172A;">R$ {{pedido_minimo}}</td>
        </tr>
        {{/if}}
        {{#if validade}}
        <tr>
          <td style="padding-top:10px; font-size:13px; color:#6B7280;">Válido até</td>
          <td align="right" style="padding-top:10px; font-size:13px; font-weight:700; color:#0F172A;">{{validade}}</td>
        </tr>
        {{/if}}
      </table>
    </td>
  </tr>
</table>

{{#if cardapio_url}}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" class="btn" style="margin:26px 0 0;">
  <tr>
    <td align="center" bgcolor="#FC5B24" style="border-radius:12px;">
      <a href="{{cardapio_url}}" style="display:inline-block; padding:15px 32px; font-size:15px; font-weight:700; color:#FFFFFF; text-decoration:none; border-radius:12px;">Usar meu cupom</a>
    </td>
  </tr>
</table>
{{/if}}
