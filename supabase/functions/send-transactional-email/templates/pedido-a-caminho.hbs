<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 14px;">
  <tr>
    <td style="background-color:#FFF7F4; border-radius:999px; padding:7px 14px;">
      <span style="font-size:11px; font-weight:800; letter-spacing:1.1px; text-transform:uppercase; color:#C2410C;">Saiu para entrega</span>
    </td>
  </tr>
</table>

<h1 class="h1" style="margin:0 0 12px; font-size:26px; line-height:1.22; font-weight:800; color:#0F172A; letter-spacing:-0.6px;">Seu pedido saiu para entrega</h1>

<p style="margin:0 0 26px; font-size:15px; line-height:1.7; color:#4B5563;">
  {{#if cliente_nome}}{{cliente_nome}}, o{{else}}O{{/if}} pedido <strong style="color:#0F172A;">#{{pedido_numero}}</strong> acabou de sair da <strong style="color:#0F172A;">{{loja.nome}}</strong> e está a caminho.
</p>

<!-- Linha do tempo do pedido -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F7F9FC; border:1px solid #E4EAF2; border-radius:14px;">
  <tr>
    <td style="padding:20px 22px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td width="24" style="width:24px; vertical-align:top; padding-bottom:14px;">
            <div style="width:11px; height:11px; border-radius:999px; background-color:#047857; margin-top:3px;">&nbsp;</div>
          </td>
          <td style="padding-bottom:14px; font-size:14px; color:#6B7280; line-height:1.4;">Pedido confirmado</td>
        </tr>
        <tr>
          <td width="24" style="width:24px; vertical-align:top; padding-bottom:14px;">
            <div style="width:11px; height:11px; border-radius:999px; background-color:#047857; margin-top:3px;">&nbsp;</div>
          </td>
          <td style="padding-bottom:14px; font-size:14px; color:#6B7280; line-height:1.4;">Preparo finalizado</td>
        </tr>
        <tr>
          <td width="24" style="width:24px; vertical-align:top;">
            <div style="width:13px; height:13px; border-radius:999px; background-color:#FC5B24; border:3px solid #FFE0D5; margin-top:1px;">&nbsp;</div>
          </td>
          <td style="font-size:15px; font-weight:800; color:#0F172A; line-height:1.4;">A caminho do seu endereço</td>
        </tr>
      </table>
    </td>
  </tr>
</table>

{{#if entregador_nome}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:18px; border:1px solid #E4EAF2; border-radius:14px;">
  <tr>
    <td style="padding:16px 20px;">
      <div style="font-size:11px; font-weight:700; letter-spacing:1.1px; text-transform:uppercase; color:#8A93A3;">Quem vai te entregar</div>
      <div style="font-size:15px; font-weight:700; color:#0F172A; margin-top:5px;">{{entregador_nome}}</div>
    </td>
  </tr>
</table>
{{/if}}

{{#if endereco_entrega}}
<p style="margin:20px 0 0; font-size:14px; line-height:1.6; color:#6B7280;">
  Entregando em<br><strong style="color:#0F172A; font-size:15px;">{{endereco_entrega}}</strong>
</p>
{{/if}}

{{#if acompanhar_url}}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" class="btn" style="margin:26px 0 0;">
  <tr>
    <td align="center" bgcolor="#FC5B24" style="border-radius:12px;">
      <a href="{{acompanhar_url}}" style="display:inline-block; padding:15px 32px; font-size:15px; font-weight:700; color:#FFFFFF; text-decoration:none; border-radius:12px;">Acompanhar a entrega</a>
    </td>
  </tr>
</table>
{{/if}}
