<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 14px;">
  <tr>
    <td style="background-color:#E7F8F0; border-radius:999px; padding:7px 14px;">
      <span style="font-size:11px; font-weight:800; letter-spacing:1.1px; text-transform:uppercase; color:#047857;">&#10003;&nbsp; Pagamento aprovado</span>
    </td>
  </tr>
</table>

<h1 class="h1" style="margin:0 0 12px; font-size:26px; line-height:1.22; font-weight:800; color:#0F172A; letter-spacing:-0.6px;">Recebemos o seu pagamento</h1>

<p style="margin:0 0 28px; font-size:15px; line-height:1.7; color:#4B5563;">
  {{#if cliente_nome}}{{cliente_nome}}, o{{else}}O{{/if}} pagamento do pedido <strong style="color:#0F172A;">#{{pedido_numero}}</strong> foi confirmado.
  <strong style="color:#0F172A;">{{loja.nome}}</strong> já recebeu o aviso e começou a preparar.
</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F7F9FC; border:1px solid #E4EAF2; border-radius:14px;">
  <tr>
    <td style="padding:20px 22px 16px;">
      <div style="font-size:11px; font-weight:700; letter-spacing:1.1px; text-transform:uppercase; color:#8A93A3;">Valor pago</div>
      <div style="font-size:30px; font-weight:800; color:#004198; margin-top:4px; letter-spacing:-0.8px;">R$ {{valor}}</div>
    </td>
  </tr>
  <tr>
    <td style="padding:0 22px 18px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-top:1px solid #E4EAF2;">
        <tr>
          <td style="padding-top:14px; font-size:13px; color:#6B7280;">Forma de pagamento</td>
          <td align="right" style="padding-top:14px; font-size:13px; font-weight:700; color:#0F172A;">{{metodo}}{{#if ultimos_digitos}} &middot; final {{ultimos_digitos}}{{/if}}</td>
        </tr>
        {{#if data_pagamento}}
        <tr>
          <td style="padding-top:10px; font-size:13px; color:#6B7280;">Data</td>
          <td align="right" style="padding-top:10px; font-size:13px; font-weight:700; color:#0F172A;">{{data_pagamento}}</td>
        </tr>
        {{/if}}
        {{#if transacao_id}}
        <tr>
          <td style="padding-top:10px; font-size:13px; color:#6B7280;">Transação</td>
          <td align="right" style="padding-top:10px; font-family:ui-monospace,SFMono-Regular,Menlo,monospace; font-size:11px; color:#6B7280; word-break:break-all;">{{transacao_id}}</td>
        </tr>
        {{/if}}
      </table>
    </td>
  </tr>
</table>

{{#if acompanhar_url}}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" class="btn" style="margin:28px 0 0;">
  <tr>
    <td align="center" bgcolor="#FC5B24" style="border-radius:12px;">
      <a href="{{acompanhar_url}}" style="display:inline-block; padding:15px 32px; font-size:15px; font-weight:700; color:#FFFFFF; text-decoration:none; border-radius:12px;">Acompanhar meu pedido</a>
    </td>
  </tr>
</table>
{{/if}}

<p style="margin:24px 0 0; font-size:13px; line-height:1.65; color:#8A93A3;">
  Guarde este e-mail como comprovante do pagamento.
</p>
