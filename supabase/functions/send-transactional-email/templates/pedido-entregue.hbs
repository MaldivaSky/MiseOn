<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 14px;">
  <tr>
    <td style="background-color:#E7F8F0; border-radius:999px; padding:7px 14px;">
      <span style="font-size:11px; font-weight:800; letter-spacing:1.1px; text-transform:uppercase; color:#047857;">&#10003;&nbsp; Pedido concluído</span>
    </td>
  </tr>
</table>

<h1 class="h1" style="margin:0 0 12px; font-size:26px; line-height:1.22; font-weight:800; color:#0F172A; letter-spacing:-0.6px;">Bom apetite!</h1>

<p style="margin:0 0 26px; font-size:15px; line-height:1.7; color:#4B5563;">
  {{#if cliente_nome}}{{cliente_nome}}, o{{else}}O{{/if}} pedido <strong style="color:#0F172A;">#{{pedido_numero}}</strong> foi entregue.
  Obrigado por pedir na <strong style="color:#0F172A;">{{loja.nome}}</strong>.
</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F7F9FC; border:1px solid #E4EAF2; border-radius:14px;">
  <tr>
    <td style="padding:18px 22px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="font-size:13px; color:#6B7280;">Pedido</td>
          <td align="right" style="font-size:13px; font-weight:700; color:#0F172A;">#{{pedido_numero}}</td>
        </tr>
        <tr>
          <td style="padding-top:10px; font-size:13px; color:#6B7280;">Total</td>
          <td align="right" style="padding-top:10px; font-size:15px; font-weight:800; color:#004198;">R$ {{valor_total}}</td>
        </tr>
        {{#if entregue_em}}
        <tr>
          <td style="padding-top:10px; font-size:13px; color:#6B7280;">Entregue em</td>
          <td align="right" style="padding-top:10px; font-size:13px; font-weight:700; color:#0F172A;">{{entregue_em}}</td>
        </tr>
        {{/if}}
      </table>
    </td>
  </tr>
</table>

{{#if cashback_valor}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:18px; background-color:#F0FDF6; border:1px solid #BBF0D3; border-radius:14px;">
  <tr>
    <td style="padding:18px 22px;">
      <div style="font-size:11px; font-weight:700; letter-spacing:1.1px; text-transform:uppercase; color:#047857;">Cashback creditado</div>
      <div style="font-size:24px; font-weight:800; color:#047857; margin-top:4px; letter-spacing:-0.5px;">R$ {{cashback_valor}}</div>
      <div style="font-size:13px; color:#3F7F63; margin-top:5px; line-height:1.55;">Use como desconto no seu próximo pedido na {{loja.nome}}.</div>
    </td>
  </tr>
</table>
{{/if}}

{{#if pedir_novamente_url}}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" class="btn" style="margin:26px 0 0;">
  <tr>
    <td align="center" bgcolor="#FC5B24" style="border-radius:12px;">
      <a href="{{pedir_novamente_url}}" style="display:inline-block; padding:15px 32px; font-size:15px; font-weight:700; color:#FFFFFF; text-decoration:none; border-radius:12px;">Pedir novamente</a>
    </td>
  </tr>
</table>
{{/if}}
