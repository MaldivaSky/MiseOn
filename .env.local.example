# ==== AMBIENTE LOCAL (Supabase local via `supabase start`) ====
# Estes são os valores padrão do Supabase local. Confirme rodando `supabase start`
# — ele imprime "API URL" e "anon key" no terminal. Cole a anon key exata aqui.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<cole aqui a anon key que o `supabase start` imprime>

# Fase 2 — Chat IA
GEMINI_API_KEY=
